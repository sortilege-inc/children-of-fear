    #tiOENYtlvzT9jwzGfkFNO6pT ^"Andrei Vitsin" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Andrei Vitsin"
            ^"Role" STRING "former Cossack"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 80
                ^"CON" INTEGER 80
                ^"SIZ" INTEGER 60
                ^"DEX" INTEGER 60
                ^"APP" INTEGER 55
                ^"INT" INTEGER 65
                ^"POW" INTEGER 80
                ^"EDU" INTEGER 90
            }
            ^"Hit Points" INTEGER 14
            ^"Magic Points" INTEGER 16
            ^"Luck" INTEGER 40
            ^"Move Rate" INTEGER 7
            ^"Damage Bonus" STRING "+1D4"
            ^"Build" INTEGER 1
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "60% (30/12)"
                    ^"Damage" STRING "1D3+1D4"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Scorpion blade"
                    ^"Skill Value" STRING "70% (35/14)"
                    ^"Damage" STRING "1D8+1+1D4"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "70% (35/14)"
                }
            ]
            ^"Skills" LIST OF STRING ["Climb 60%", "Cthulhu Mythos 50%", "Firearms (Rifle) 65%", "First Aid 50%", "History 80%", "Intimidate 85%", "Occult 70%", "Ride 75%", "Stealth 60%", "Survival 60%", "Other (as appropriate) 51%", "Russian (Own) 90%", "Spells: Alter Weather*, Dominate, Mindblast, Observation from Afar*, Send Vision*, plus any other spells of the Keeper's choosing", "Pulp Talent: Heavy Hitter — may spend 10 Luck points to add an additional damage die when dealing out damage in melee combat (die type depends on weapon being used)", "Pulp Talent: Tough Guy — soaks up damage; may spend 10 Luck points to shrug off up to 5 hit points worth of damage taken in one combat round"]
            ^"Description" STRING "Member of the Triumvirate, former Cossack. In a confrontation, Vitsin's first line of attack is usually to cast Dominate."
        }
    }

