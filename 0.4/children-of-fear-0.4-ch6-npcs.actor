    #tFfF0Cw05KoHxSQrA4V0W3Op ^"Abominable Mi-go" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Abominable Mi-go"
            ^"Role" STRING "researchers from Yuggoth"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 65
                ^"CON" INTEGER 55
                ^"SIZ" INTEGER 55
                ^"DEX" INTEGER 85
                ^"INT" INTEGER 65
                ^"POW" INTEGER 75
            }
            ^"Hit Points" INTEGER 11
            ^"Magic Points" INTEGER 15
            ^"Move Rate" INTEGER 7
            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Armor" STRING "1-point hide if wearing their furry disguise; no armor if lacking their migyu skin; the resonance of their bodies causes all piercing weapons (bullets included) to inflict only minimum damage."
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Fighting"
                    ^"Skill Value" STRING "40% (20/8)"
                    ^"Damage" STRING "1D6 + DB"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Seize (mnvr)"
                    ^"Skill Value" STRING "40% (20/8)"
                    ^"Damage" STRING "due to falling or 1D10 for every 1,000 feet above 24,000 feet"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "45% (22/9)"
                }
            ]
            ^"Sanity Loss" STRING "0/1D6 to see an abominable mi-go"
            ^"Description" STRING "Researchers from Yuggoth. Move 7/13 (flying). 2 attacks per round (claws), or 1 if using hypnosis or a weapon. Can hypnotize humans within 40 feet via ultra-high/low frequency tones (opposed POW roll) and speak telepathically (1 MP per 5 rounds). May be armed with matter-dissolving horns or lightning guns (35% (17/7)). Statistics shown are sample 1 (leader) of six."
        }
    }

    #tL29Yz1vht9ygCsW6hzy3PLJ ^"Migyu" DEF {
