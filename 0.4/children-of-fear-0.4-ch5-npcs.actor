            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "25% (12/5)"
                    ^"Damage" STRING "1D3"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "30% (15/6)"
                }
            ]
            ^"Skills" LIST OF STRING ["Accounting 55%", "Art/Craft (Painting) 55%", "Art/Craft (Poetry) 65%", "History (Buddhist) 65%", "Library Use 70%", "Lore (Buddhism) 71%", "Persuade 70%", "Psychology 60%", "Spot Hidden 75%", "Chinese 51%", "Sanskrit 70%", "Tibetan (Own) 70%"]
            ^"Description" STRING "Age 65, head monk at Derge Parkhang."
        }
    }

