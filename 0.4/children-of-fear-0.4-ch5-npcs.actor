    #t6Ti9UIfXTupHzMnfjU1jt3W ^"Dakini In Human Form" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Dakini In Human Form"
            ^"Role" STRING "divine protectors (The Seven Sisters)"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 70
                ^"CON" INTEGER 75
                ^"SIZ" INTEGER 70
                ^"DEX" INTEGER 100
                ^"APP" INTEGER 100
                ^"INT" INTEGER 75
                ^"POW" INTEGER 85
            }
            ^"Hit Points" INTEGER 14
            ^"Magic Points" INTEGER 17
            ^"Move Rate" INTEGER 8
            ^"Damage Bonus" STRING "+1D4"
            ^"Build" INTEGER 1
            ^"Armor" STRING "none"
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Attacks per round"
                    ^"Description" STRING "1 (katari or power). Besides their kataris (ritual flaying knives), the Seven Sisters have numerous mystical powers they can use in combat."
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "40% (20/8)"
                    ^"Damage" STRING "1D3+DB or katari 1D6+DB"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "40% (20/8)"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Eye of the Beholder"
                    ^"Description" STRING "May assume whatever form their target finds most appealing in order to effectively use their wiles against them. The result may be to cause distraction, pause, or garner a particular emotion (in all likelihood causing an investigator to stop their next attack). The target must succeed with an opposed POW roll to negate the dakini's manipulation."
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Seductive Dance"
                    ^"Description" STRING "A dakini in its beautiful human guise has the power to entrance a true human with their seductive dance. Unless the target succeeds with an opposed POW roll, they fall under the dakini's spell for 1D6 rounds and are frozen to the spot, unable to move or act."
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Invisibility"
                    ^"Description" STRING "Unless a dakini wishes to be seen, it can remain invisible; although may be revealed by the Powder of Ibn-Ghazi. The dakini may become visible with the expenditure of 1 magic point. Attempts to hit an invisible dakini suffer one penalty die."
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Summon Khandroma"
                    ^"Description" STRING "Spell. See Appendix B."
                }
            ]
            ^"Skills" LIST OF STRING ["Art/Craft (Dance) 90%", "Listen 65%", "Spot Hidden 65%", "any (as required) 75%", "Khandro Dayig (the twilight language of the dakinis) (Own) 95%"]
            ^"Sanity Loss" STRING "0/1D3"
            ^"Description" STRING "The Seven Sisters, among the most powerful dakinis, guardians and protectors of their country. Stats vary by sister (columns 1-7); values shown are for the Red sister."
        }
    }

    #tGRdOufpPTsYhm482ibD9Dby ^"Dakini In Demon Form" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Dakini In Demon Form"
            ^"Role" STRING "divine protectors (The Seven Sisters)"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 90
                ^"CON" INTEGER 90
                ^"SIZ" INTEGER 90
                ^"DEX" INTEGER 100
                ^"INT" INTEGER 75
                ^"POW" INTEGER 85
            }
            ^"Hit Points" INTEGER 18
            ^"Magic Points" INTEGER 17
            ^"Move Rate" INTEGER 7
            ^"Damage Bonus" STRING "+1D6"
            ^"Build" INTEGER 2
            ^"Armor" STRING "3-points of tough hide"
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Attacks per round"
                    ^"Description" STRING "1 (claw, bite). Once transformed, the Seven Sisters dispense with their kataris, using their claws and bite instead. They still have access to the Invisibility special power, but their change of form negates their ability to use the other powers available to them in human form."
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Claw"
                    ^"Skill Value" STRING "50% (25/10)"
                    ^"Damage" STRING "1D8+DB"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Bite"
                    ^"Skill Value" STRING "35% (17/7)"
                    ^"Damage" STRING "1D6+DB"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "45% (22/9)"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Invisibility"
                    ^"Description" STRING "Unless a dakini wishes to be seen, it can remain invisible; although may be revealed by the Powder of Ibn-Ghazi. The dakini may become visible with the expenditure of 1 magic point. Attempts to hit an invisible dakini suffer one penalty die."
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Summon Khandroma"
                    ^"Description" STRING "Spell, +1D3 spells of the Keeper's choosing if their POW is greater than 75. See Appendix B."
                }
            ]
            ^"Skills" LIST OF STRING ["Listen 65%", "Spot Hidden 65%", "Stealth 65%", "any (as required) 75%", "Khandro Dayig (the twilight language of the dakinis) (Own) 95%"]
            ^"Sanity Loss" STRING "1/1D8"
            ^"Description" STRING "Transformed Seven Sisters, using claws and bite instead of kataris. Stats vary by sister (columns 1-7); values shown are for the Red sister."
        }
    }

}
