EXTENSION "ChildrenOfFear_Ch5_NPCs" EXTENDS "CallOfCthulhu7e_Core_Base" {
    NAME "The Children of Fear - Chapter 5 NPCs"
    VERSION "0.4"
    SPEC_VERSION "0.4"
    RELEASE_DATE "2026-07-17"

    #tqMK08ZMQGZmAsqrhXWYaClG ^"Yonten Phuntsok" DEF {
