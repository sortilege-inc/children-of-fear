            ^"Build" INTEGER 1
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "55% (27/11)"
                    ^"Damage" STRING "1D3+1D4"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Mauser C96 pistol"
                    ^"Skill Value" STRING "65% (32/13)"
                    ^"Damage" STRING "1D10+2"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "55% (27/11)"
                }
            ]
            ^"Skills" LIST OF STRING ["Art/Craft (Acting) 50% (25/10)", "Credit Rating 20% (10/4)", "Firearms (Rifle) 40% (20/8)", "First Aid 50% (25/10)", "History (Art) 45% (22/9)", "Intimidate 65% (32/13)", "Language (Chinese) 35% (17/7)", "Language (English) 25% (12/5)", "Language (Russian) 60% (30/12)", "Listen 60% (30/12)", "Navigate 30% (15/6)", "Psychology 60% (30/12)", "Spot Hidden 45% (22/9)", "Stealth 50% (25/10)", "Survival (Desert) 30% (15/6)", "Throw 35% (17/7)"]
            ^"Description" STRING "Once hoping to join the Imperial Russian Ballet, Repin was drafted in the Great War and served on the Eastern Front before fleeing to Peking in 1920. He built a new life as a janitor at Yenching University and art history assistant to Dr. Eudora Lockhart. In truth, sickened by Tsarist decadence, he secretly joined the Bolsheviks and is a Soviet spy sent to report on the White Russian expatriate community. He is immune to Sanity loss from viewing a corpse or gross injury and suffers ligyrophobia."
        }
    }

    #tygY5LCgf2BqvS4TMoZtRjYH ^"Sofian Bazaz-Wain" DEF {
