            ^"Hit Points" INTEGER 12
            ^"Magic Points" INTEGER 13
            ^"Sanity" INTEGER 65
            ^"Move Rate" INTEGER 7
            ^"Damage Bonus" STRING "+1D4"
            ^"Build" INTEGER 1
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "25% (12/5)"
                    ^"Damage" STRING "1D3+1D4"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "45% (22/9)"
                }
            ]
            ^"Skills" LIST OF STRING ["Anthropology 25% (12/5)", "Credit Rating 10% (5/2)", "First Aid 45% (22/9)", "Language (Chinese) 55% (27/11)", "Language (English) 65% (32/13)", "Lore (Buddhism) 25% (12/5)", "Lore (Christianity) 50% (25/10)", "Lore (Other Faiths) 30% (15/6)", "Medicine 30% (15/6)", "Natural World 30% (15/6)", "Persuade 50% (25/12)", "Psychology 50% (25/12)", "Spot Hidden 50% (25/12)", "Survival (Desert) 30% (15/6)"]
            ^"Description" STRING "Born Li Jianyu to a poor family in Shantung Province, he lost his parents in the Boxer Rebellion and was rescued by Scottish Protestant missionary Grace Strachan, surviving the siege of Peking's Foreign Legation Quarter. Raised as Michael in his adopted faith, he traveled across Kokonor and Sinkiang aiding his mother's missionary work for the China Inland Mission. He has a keen interest in Muslim, Buddhist, and Taoist faiths and is secretly writing a manuscript about his travels."
        }
    }

    #tyW3Y5ytBOLvd69z9bVJ7zUE ^"Timur Stepanovich Repin" DEF {
