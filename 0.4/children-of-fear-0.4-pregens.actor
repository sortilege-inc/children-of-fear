                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "30% (15/6)"
                }
            ]
            ^"Skills" LIST OF STRING ["Art/Craft (Photography) 65% (32/13)", "Art/Craft (Writing) 35% (17/7)", "Charm 65% (32/13)", "Climb 30% (15/6)", "Credit Rating 30% (15/6)", "First Aid 40% (20/8)", "History (Exploration) 45% (22/9)", "Language (English) 90% (45/18)", "Language (French) 35% (17/7)", "Language (Hindustani) 55% (27/11)", "Natural World 40% (20/8)", "Navigate 40% (20/8)", "Psychology 60% (30/12)", "Science (Chemistry) 40% (20/8)", "Spot Hidden 60% (30/12)", "Stealth 40% (20/8)", "Survival (Desert) 30% (15/6)"]
            ^"Description" STRING "Fascinated by explorers as a boy in Srinagar, Sofian and his brother Adem planned expeditions across the Karakorums, later making the journey across the Taklamakan Desert to Sian. His published article and photographs made him a famous freelance journalist. He worked as an expedition photographer and, during the Great War, a war correspondent. His brother Adem's death on the Western Front in 1917 drove him to continue his travels in his honor. A devotee of Islam, he is immune to Sanity loss from viewing a corpse or gross injury and suffers ecdemomania."
