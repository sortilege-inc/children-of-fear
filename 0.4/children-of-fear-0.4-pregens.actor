EXTENSION "ChildrenOfFear_Pregens" EXTENDS "CallOfCthulhu7e_Core_Base" {
    NAME "The Children of Fear - Pre-Generated Investigators"
    VERSION "0.4"
    SPEC_VERSION "0.4"
    RELEASE_DATE "2026-07-17"

    #toX0TcH9VNr4gwFR9MXha9uI ^"Chang Mei" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Chang Mei"
            ^"Role" STRING "Linguist, Yenching University"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 40
                ^"CON" INTEGER 50
                ^"SIZ" INTEGER 50
                ^"DEX" INTEGER 85
                ^"APP" INTEGER 60
                ^"INT" INTEGER 70
                ^"POW" INTEGER 70
                ^"EDU" INTEGER 80
            }
            ^"Hit Points" INTEGER 10
            ^"Magic Points" INTEGER 14
            ^"Sanity" INTEGER 70
            ^"Move Rate" INTEGER 8
            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "25% (12/5)"
                    ^"Damage" STRING "1D3"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "55% (27/11)"
                }
            ]
            ^"Skills" LIST OF STRING ["Art/Craft (Calligraphy) 35% (17/7)", "Credit Rating 30% (15/6)", "History 50% (32/13)", "Language (Chinese) 80% (40/16)", "Language (English) 50% (27/11)", "Language (Sanskrit) 60% (30/12)", "Language (Tibetan) 40% (20/8)", "Library Use 70% (35/14)", "Listen 40% (20/8)", "Lore (Buddhism) 30% (15/6)", "Persuade 50% (30/12)", "Spot Hidden 75% (37/15)", "plus one other language of the player's choice at 35% (17/7)"]
            ^"Description" STRING "One of the first women to graduate from Peking University after it opened to female students in 1920. Her flair for ancient and modern languages makes her a valuable addition to the American School of Archaeology at Yenching University, where she works with Dr. Eudora Lockhart translating and cataloguing manuscripts. Known as \"Mei Mei,\" she is a conscientious, gifted, and quietly devout Buddhist scholar from an old, respected Peking family."
        }
    }

    #tJGEcKgD88Z6pwt9CXmhmTPs ^"Dr. Eudora Lockhart" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Dr. Eudora Lockhart"
            ^"Role" STRING "Archaeologist, Yenching University"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 60
                ^"CON" INTEGER 45
                ^"SIZ" INTEGER 60
                ^"DEX" INTEGER 45
                ^"APP" INTEGER 70
                ^"INT" INTEGER 75
                ^"POW" INTEGER 65
                ^"EDU" INTEGER 90
            }
            ^"Hit Points" INTEGER 10
            ^"Magic Points" INTEGER 13
            ^"Sanity" INTEGER 65
            ^"Move Rate" INTEGER 7
            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "25% (12/5)"
                    ^"Damage" STRING "1D3"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Purdey shotgun (12-g, DB)"
                    ^"Skill Value" STRING "55% (27/11)"
                    ^"Damage" STRING "4D6/2D6/1D6"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "45% (22/9)"
                }
            ]
            ^"Skills" LIST OF STRING ["Appraise 50% (25/10)", "Archaeology 70% (35/14)", "Credit Rating 40% (20/8)", "History 65% (32/13)", "Language (Chinese) 25% (12/5)", "Language (English) 90% (45/18)", "Language (Italian) 40% (20/8)", "Library Use 65% (32/13)", "Mechanical Repair 20% (10/4)", "Navigate 40% (20/8)", "Ride 40% (20/8)", "Spot Hidden 60% (30/12)", "Survival (Desert) 40% (20/8)"]
            ^"Description" STRING "A formidable woman who worked her way up in a male-dominated discipline, trained at University College London under Prof. William Flinders Petrie. Born to wealthy British industrialist Jeremiah Jessop and his Venetian wife, she traveled widely as a child. She married American diplomat Charles Lockhart in Shanghai, later joining Peking's American School of Archaeology as its first female archaeology lecturer. She dreams of making discoveries at the Caves of the Thousand Buddhas."
        }
    }

    #taseK7fx9V988NsQpos39bXv ^"Charles Lockhart" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Charles Lockhart"
            ^"Role" STRING "Diplomat"
            ^"Characteristics" DEF {
