            ^"Damage Bonus" STRING "+1D4"
            ^"Build" INTEGER 1
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "35% (17/7)"
                    ^"Damage" STRING "1D3+1D4"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "30% (15/6)"
                }
            ]
            ^"Skills" LIST OF STRING ["Charm 55% (27/11)", "Credit Rating 40% (20/8)", "Fast Talk 65% (32/13)", "History 60% (30/12)", "Intimidate 50% (25/10)", "Language (Chinese) 55% (32/11)", "Language (English) 75% (37/15)", "Listen 60% (30/12)", "Persuade 65% (32/13)", "Psychology 60% (30/12)"]
            ^"Description" STRING "A capable athlete and popular socialite with a way with people. After his arranged fiancée eloped on their wedding day, Charles joined the US Diplomatic Corps and shipped out to Shanghai as a junior clerk to the American Legation, where he fell in love with British adventuress Eudora Jessop. Now stationed in Peking, his evenhandedness and insistence on treating everyone as equals infuriates his stuffier superiors, but he remains good at his job."
        }
    }

    #tz4BFTDTfExkfSv04fvTsQNK ^"Michael Li" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Michael Li"
            ^"Role" STRING "Christian Missionary"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 60
                ^"CON" INTEGER 60
