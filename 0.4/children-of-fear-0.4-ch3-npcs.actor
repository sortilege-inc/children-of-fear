            ^"Move Rate" INTEGER 8
            ^"Damage Bonus" STRING "+1D4"
            ^"Build" INTEGER 1
            ^"Armor" STRING "none"
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Fighting"
                    ^"Skill Value" STRING "45% (22/9)"
                    ^"Damage" STRING "1D3+1D4"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "45% (22/9)"
                }
            ]
            ^"Skills" LIST OF STRING ["Dodge 50%", "Jump 70%", "Listen 50%", "Psychology 60%", "Stealth 70%", "Chinese 45%", "Gandhari 60%", "Khotanese (Own) 60%"]
            ^"Sanity Loss" STRING "1/1D6 Sanity points to encounter the Rat King"
            ^"Description" STRING "A bizarre hybrid with the body of a man and the head of a giant rat, wearing the golden jeweled Diadem of the Rat King. Once a great sorcerer revered as a god, transformed into the rats' eternal ruler after making a dark pact to protect Khotan. Attacks per round: 1 (claw, bite), but prefers to leave combat to its rat packs and rat-things. Spells: Bind Rat, Charm Rat, Command Rat, Contact Rat-thing, Curse of the Rat Thing, Evil Eye, Lame/Heal Animal, Warding the Eye."
        }
    }

