    #tyHvotBKjJKOCnE83eV6iDUs ^"Rat King" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Rat King"
            ^"Role" STRING "sorcerous guardian of Khotan"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 70
                ^"CON" INTEGER 95
                ^"SIZ" INTEGER 70
                ^"DEX" INTEGER 85
                ^"POW" INTEGER 120
            }
            ^"Hit Points" INTEGER 18
