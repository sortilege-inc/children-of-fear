                    ^"Skill Value" STRING "30% (15/6)"
                }
            ]
            ^"Sanity Loss" STRING "0/1D4 Sanity points to encounter a walking portrait"
            ^"Description" STRING "The likenesses of animals and people, as though ripped from a painting; oddly three-dimensional yet retaining a distinct flatness, with plain backs matching the surface on which they were drawn. On moonless nights they peel themselves from their frescoes with a sound like tearing cloth to walk the ruins until daylight drives them back. Human portraits fight with whatever weapon they were painted with; if unarmed they use bare hands. Attacks per round: 1 (varies). Can be neutralized by removing painted eyes and mouth during daylight."
        }
    }

