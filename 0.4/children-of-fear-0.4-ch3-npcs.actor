    #tGufFXL5y6mhnyhl24hEYxVs ^"Hasina Moiz" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Hasina Moiz"
            ^"Role" STRING "terrified cannibal"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 50
                ^"CON" INTEGER 85
                ^"SIZ" INTEGER 45
                ^"DEX" INTEGER 80
                ^"APP" INTEGER 75
                ^"INT" INTEGER 75
                ^"POW" INTEGER 55
                ^"EDU" INTEGER 30
            }
            ^"Hit Points" INTEGER 13
            ^"Magic Points" INTEGER 11
            ^"Sanity" INTEGER 45
            ^"Move Rate" INTEGER 9
            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "25% (12/5)"
                    ^"Damage" STRING "1D3"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "40% (20/8)"
                }
            ]
            ^"Skills" LIST OF STRING ["Art/Craft (Dance) 40%", "Art/Craft (Sing) 30%", "Climb 30%", "History 45%", "Jump 40%", "Natural World 40%", "Spot Hidden 45%", "Stealth 40%", "Survival (Mountain) 40%", "English 20%", "Hindustani 50%", "Shina (Own) 60%"]
            ^"Description" STRING "Age 18. Previously an attractive young woman, warped by her ordeal into a fearful, self-loathing madwoman convinced she died and returned as a pisacha cursed to feast on the dead; currently suffering an indefinite insanity."
        }
    }

