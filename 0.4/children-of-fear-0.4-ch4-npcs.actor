    #tFazkQj95AVrs1GcVms2Om3f ^"Scorpion Demon" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Scorpion Demon"
            ^"Role" STRING "arachnid terror"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 110
                ^"CON" INTEGER 100
                ^"SIZ" INTEGER 80
                ^"DEX" INTEGER 50
                ^"POW" INTEGER 80
            }
            ^"Hit Points" INTEGER 18
            ^"Magic Points" INTEGER 16
            ^"Move Rate" INTEGER 8
            ^"Damage Bonus" STRING "+1D6"
            ^"Build" INTEGER 2
            ^"Armor" STRING "3-point chitinous scale armor"
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Fighting"
                    ^"Skill Value" STRING "45% (22/9)"
                    ^"Damage" STRING "1D6+DB (pincer) or 1D3+1D10 poison damage (stinger)"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Grab (mnvr)"
                    ^"Skill Value" STRING "45% (22/9)"
                    ^"Damage" STRING "3D3+DB"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "35% (17/7)"
                }
            ]
            ^"Sanity Loss" STRING "0/1D6 Sanity points to encounter a scorpion demon"
            ^"Description" STRING "Arachnid terror. Attacks 3 per round (pincers and stinger). Terton: sensitive to sacred and magical texts, can lead its summoner to such items within 80 yards. Stinger poison inflicts extra damage unless an Extreme CON roll succeeds."
        }
    }

    #t7AUXMLdN6BnsHNMzNhBdljo ^"Shri Chitipati" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Shri Chitipati"
            ^"Role" STRING "Lord and Lady of the Charnel Grounds"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 90
                ^"SIZ" INTEGER 95
                ^"DEX" INTEGER 80
                ^"POW" INTEGER 100
            }
            ^"Magic Points" INTEGER 20
            ^"Move Rate" INTEGER 7
            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Armor" STRING "none; resistant to harm"
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Fighting"
                    ^"Skill Value" STRING "55% (27/11)"
                    ^"Damage" STRING "1D8"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "40% (20/8)"
                }
            ]
            ^"Skills" LIST OF STRING ["Art/Craft (Dance) 90%"]
            ^"Sanity Loss" STRING "1/1D8 Sanity points to see the Shri Chitipati"
            ^"Description" STRING "Lord and Lady of the Charnel Grounds. Attacks 1 per round with corpse club. Resistant to harm: brittle bones may shatter (multiply damage by 5, roll 1D100 to destroy); one penalty die to impaling weapon attacks."
        }
    }

    #tTiEjfMvTXLXkaJnHvwuws0k ^"Skeletons" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
