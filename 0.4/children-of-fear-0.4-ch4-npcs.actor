            ^"Armor" STRING "none; resistant to harm"
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Fighting"
                    ^"Skill Value" STRING "45% (22/9)"
                    ^"Damage" STRING "1D3+DB, or club/sword 1D6+DB"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "30% (15/6)"
                }
            ]
            ^"Sanity Loss" STRING "0/1D6 Sanity points to see an animated skeleton"
            ^"Description" STRING "Dancing dead; six animated skeletons with varying statistics (values shown are for the first). Resistant to harm: any blow may destroy it (damage x5 vs 1D100); one penalty die on impaling attacks. Use weapons rather than attacking unarmed because they shatter easily."
        }
    }

}
