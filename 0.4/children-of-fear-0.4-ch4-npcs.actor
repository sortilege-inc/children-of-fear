    RELEASE_DATE "2026-07-17"

    #tmogEARljV0Q4oIic1gYtm3y ^"Aghor Kalidasji" DEF {
        EXTENDS #COCnpcactor000000001 ^"Non-Player Character"
        PROPERTIES {
            ^"Name" STRING "Aghor Kalidasji"
            ^"Role" STRING "tantric ascetic"
            ^"Characteristics" DEF {
                ^"STR" INTEGER 50
                ^"CON" INTEGER 55
                ^"SIZ" INTEGER 70
                ^"DEX" INTEGER 50
                ^"APP" INTEGER 20
                ^"INT" INTEGER 80
                ^"POW" INTEGER 85
                ^"EDU" INTEGER 70
            }
            ^"Hit Points" INTEGER 12
            ^"Magic Points" INTEGER 17
            ^"Sanity" INTEGER 55
            ^"Luck" INTEGER 45
            ^"Move Rate" INTEGER 6
            ^"Damage Bonus" STRING "0"
            ^"Build" INTEGER 0
            ^"Attacks" LIST OF [
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Brawl"
                    ^"Skill Value" STRING "25% (12/5)"
                    ^"Damage" STRING "1D3 or knife 1D4+2"
                },
                ^"Creature Attack" DEF {
                    ^"Attack" STRING "Dodge"
                    ^"Skill Value" STRING "45% (22/9)"
                }
            ]
            ^"Skills" LIST OF STRING ["Cthulhu Mythos 30%", "History 65%", "Intimidate 65%", "Listen 60%", "Lore (Hinduism) 65%", "Natural World 50%", "Occult 60%", "Psychology 60%", "Spot Hidden 60%", "Throw 50%", "English (Own) 70%", "Hindustani (Own) 70%", "Sanskrit 51%", "Pulp Talent: Endurance", "Pulp Talent: Scary", "Spell: Bless", "Spell: Cause Disease", "Spell: Cleansing Ritual", "Spell: Curse", "Spell: Demon Senses", "Spell: Detect Enchantment", "Spell: Dismiss Spirit", "Spell: Earthly Serenity", "Spell: Empty Mind", "Spell: Endurance Chant", "Spell: Evil Eye", "Spell: Food of Life", "Spell: Healing", "Spell: Nyhargo Dirge", "Spell: Summon/Bind Scorpion Demon", "Spell: Wandering Soul", "Spell: Warding the Eye"]
            ^"Description" STRING "Age 99, tantric ascetic."
        }
    }

    #tkZMkNRmAYfBBBVkRB73w1Zc ^"Sanjit Chopra" DEF {
